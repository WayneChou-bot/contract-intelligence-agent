# Copy to .env and fill in. NEVER commit the real .env.

# --- Model backend ----------------------------------------------------------
# "gemini" = cloud (default, convenient for demos)
# "local"  = Ollama + a local model; nothing leaves your machine (on-prem)
MODEL_BACKEND=gemini

# Cloud (gemini) mode only. Get a key: https://aistudio.google.com/app/apikey
# NOTE: the free AI Studio tier may use your data to improve Google products and
# may be human-reviewed. Use a PAID/Vertex key, or MODEL_BACKEND=local, for
# anything sensitive.
GOOGLE_API_KEY=your_api_key_here
GEMINI_API_KEY=your_api_key_here
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Local mode only (ignored in cloud mode):
#   pip install google-adk[extensions]   # LiteLLM bridge
#   ollama pull gemma4 ; ollama serve
OLLAMA_MODEL=gemma4
OLLAMA_API_BASE=http://localhost:11434

# OCR is always deterministic/on-device (Tesseract); pick languages to load.
OCR_LANG=eng+chi_tra
# Windows only: if tesseract.exe is not on PATH, point to it directly.
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
